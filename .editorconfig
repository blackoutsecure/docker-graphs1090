root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = false
charset = utf-8

[{Dockerfile,**.yml,**.yaml}]
indent_style = space
indent_size = 2

[{**.sh,root/etc/s6-overlay/s6-rc.d/**}]
indent_style = space
indent_size = 4

[**.py]
indent_style = space
indent_size = 4

[**.json]
indent_style = space
indent_size = 2

[**.md]
trim_trailing_whitespace = false

[**.conf]
indent_style = space
indent_size = 4
